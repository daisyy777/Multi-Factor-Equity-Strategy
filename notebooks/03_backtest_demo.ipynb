{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Backtest Demo\n",
        "\n",
        "Load and visualise the results of a completed backtest.\n",
        "Run `python scripts/run_backtest.py` first if `results/` is empty.\n",
        "\n",
        "**Actual results (2018-01-01 → 2026-02-03, bias-corrected)**\n",
        "| Metric | Value |\n",
        "|--------|-------|\n",
        "| Annualized Return | -6.30% |\n",
        "| Sharpe Ratio | -0.29 |\n",
        "| Max Drawdown | -63.46% |\n",
        "| Value factor IC | 0.150 (strong) |\n",
        "| Momentum factor IC | 0.003 (weak) |\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import sys\n",
        "from pathlib import Path\n",
        "\n",
        "project_root = Path().resolve().parent\n",
        "sys.path.insert(0, str(project_root))\n",
        "\n",
        "import json\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "from src.utils.config import RESULTS_DIR, FIGURES_DIR\n",
        "from src.backtester.metrics import format_metrics_report\n",
        "from src.analysis import generate_all_plots\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## 1. Load results\n"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "try:\n",
        "    backtest_results = pd.read_parquet(RESULTS_DIR / 'backtest_results.parquet')\n",
        "    with open(RESULTS_DIR / 'metrics.json') as f:\n",
        "        metrics = json.load(f)\n",
        "    print(f\"Date range: {backtest_results.index.min()} to {backtest_results.index.max()}\")\n",
        "    print(f\"Final NAV : ${backtest_results['nav'].iloc[-1]:,.2f}\")\n",
        "    print()\n",
        "    print(format_metrics_report(metrics))\n",
        "except FileNotFoundError:\n",
        "    print(\"No results found. Run: python scripts/run_backtest.py\")\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## 2. NAV & drawdown\n"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "fig, axes = plt.subplots(2, 1, figsize=(14, 9))\n",
        "\n",
        "# NAV\n",
        "axes[0].plot(backtest_results.index, backtest_results['nav'], color='steelblue')\n",
        "axes[0].axhline(backtest_results['nav'].iloc[0], color='grey', linestyle='--', linewidth=0.8)\n",
        "axes[0].set_title('Portfolio NAV')\n",
        "axes[0].set_ylabel('NAV ($)')\n",
        "axes[0].grid(True, alpha=0.3)\n",
        "\n",
        "# Drawdown\n",
        "nav = backtest_results['nav']\n",
        "dd = (nav - nav.expanding().max()) / nav.expanding().max()\n",
        "axes[1].fill_between(dd.index, dd.values, 0, color='salmon', alpha=0.7)\n",
        "axes[1].set_title('Drawdown')\n",
        "axes[1].set_ylabel('Drawdown (%)')\n",
        "axes[1].grid(True, alpha=0.3)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## 3. IC results\n"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "try:\n",
        "    ic_summary = pd.read_csv(RESULTS_DIR / 'ic_summary.csv', index_col=0)\n",
        "    print(\"=== Factor IC Summary ===")\n",
        "    print(ic_summary.to_string())\n",
        "except FileNotFoundError:\n",
        "    print(\"IC summary not found. Re-run the backtest.\")\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## 4. Long / short decomposition\n"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "fig, ax = plt.subplots(figsize=(14, 5))\n",
        "ax.plot(backtest_results.index, backtest_results['long_value'], label='Long leg', color='green', alpha=0.8)\n",
        "ax.plot(backtest_results.index, backtest_results['short_value'], label='Short leg', color='red', alpha=0.8)\n",
        "ax.set_title('Long / Short Leg Market Value')\n",
        "ax.set_ylabel('Market Value ($)')\n",
        "ax.legend()\n",
        "ax.grid(True, alpha=0.3)\n",
        "plt.tight_layout()\n",
        "plt.show()\n"
      ]
    }
  ],
