{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Factor Research\n",
        "\n",
        "Explore individual factor scores, their cross-sectional distributions,\n",
        "correlations, and predictive power (IC analysis) before running the full backtest.\n",
        "\n",
        "**Methodology note**: `download_fundamental_data()` fetches *historical* quarterly\n",
        "income-statement and balance-sheet data from yfinance, timestamped as\n",
        "`quarter_end + 60 days` to avoid look-ahead bias.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import sys\n",
        "from pathlib import Path\n",
        "\n",
        "project_root = Path().resolve().parent\n",
        "sys.path.insert(0, str(project_root))\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "from src.data_loader import load_universe, download_price_data, download_fundamental_data\n",
        "from src.data_preprocess import preprocess_data\n",
        "from src.backtester import get_rebalance_dates\n",
        "from src.factors import (\n",
        "    compute_value_factor_panel,\n",
        "    compute_momentum_factor_panel,\n",
        "    compute_quality_factor_panel,\n",
        ")\n",
        "from src.analysis import compute_ic_panel, summarise_ic, plot_ic_tearsheet\n",
        "from src.utils.config import BACKTEST_CONFIG, FACTOR_CONFIG, FIGURES_DIR\n",
        "\n",
        "plt.style.use('seaborn-v0_8' if 'seaborn-v0_8' in plt.style.available else 'default')\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## 1. Load & preprocess data\n"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "universe_df = load_universe()\n",
        "tickers = universe_df['ticker'].tolist()\n",
        "\n",
        "data_start = (pd.Timestamp(BACKTEST_CONFIG.start_date) - pd.DateOffset(months=15)).strftime('%Y-%m-%d')\n",
        "\n",
        "# Prices are cached; fundamentals use historical quarterly statements (60-day lag)\n",
        "price_data = download_price_data(tickers, data_start, BACKTEST_CONFIG.end_date, cache=True)\n",
        "fundamental_data = download_fundamental_data(tickers, data_start, BACKTEST_CONFIG.end_date, cache=True)\n",
        "\n",
        "clean_prices, clean_fundamentals, market_cap, eligible_tickers = preprocess_data(\n",
        "    price_data, fundamental_data\n",
        ")\n",
        "print(f\"Eligible tickers: {len(eligible_tickers)}\")\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## 2. Compute factors\n"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "backtest_prices = clean_prices.loc[\n",
        "    clean_prices.index.get_level_values('date') >= pd.Timestamp(BACKTEST_CONFIG.start_date)\n",
        "]\n",
        "trading_dates = backtest_prices.index.get_level_values('date').unique().sort_values()\n",
        "rebalance_dates = get_rebalance_dates(trading_dates, BACKTEST_CONFIG.rebalance_frequency)\n",
        "print(f\"Rebalance dates: {len(rebalance_dates)}\")\n",
        "\n",
        "fund_arg = clean_fundamentals if clean_fundamentals is not None else clean_prices[[]]\n",
        "\n",
        "value_factor    = compute_value_factor_panel(clean_prices, fund_arg, market_cap, rebalance_dates)\n",
        "momentum_factor = compute_momentum_factor_panel(clean_prices, rebalance_dates)\n",
        "quality_factor  = compute_quality_factor_panel(clean_prices, fund_arg, market_cap, rebalance_dates)\n",
        "\n",
        "all_factors = pd.concat({\n",
        "    'value_factor':    value_factor,\n",
        "    'momentum_factor': momentum_factor,\n",
        "    'quality_factor':  quality_factor,\n",
        "}, axis=1)\n",
        "if hasattr(all_factors.columns, 'droplevel'):\n",
        "    all_factors.columns = all_factors.columns.droplevel(1)\n",
        "print(all_factors.describe())\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## 3. Factor correlations\n"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "corr = all_factors.corr()\n",
        "print(\"Factor Correlation Matrix:\")\n",
        "print(corr.round(3))\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(6, 5))\n",
        "sns.heatmap(corr, annot=True, fmt='.2f', cmap='coolwarm', center=0, square=True, ax=ax)\n",
        "ax.set_title('Factor Correlation Matrix')\n",
        "plt.tight_layout()\n",
        "plt.show()\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 4. IC Analysis\n",
        "\n",
        "IC = Spearman rank correlation between factor scores at *t* and forward returns at *t+1*.\n",
        "Rule of thumb: `|IC| > 0.05` strong, `|IC| > 0.02` marginal, `|IC| < 0.02` weak.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "ic_panel = compute_ic_panel(all_factors, clean_prices, rebalance_dates)\n",
        "ic_summary = summarise_ic(ic_panel)\n",
        "\n",
        "print(\"=== IC Summary ===")\n",
        "print(ic_summary.to_string())\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# IC tear-sheet (time series + cumulative IC + summary table)\n",
        "plot_ic_tearsheet(\n",
        "    ic_panel,\n",
        "    output_path=str(FIGURES_DIR / 'ic_tearsheet_research.png'),\n",
        "    show=True,\n",
        ")\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## 5. Factor score distributions\n"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "fig, axes = plt.subplots(1, len(all_factors.columns), figsize=(5 * len(all_factors.columns), 4))\n",
        "for ax, col in zip(axes, all_factors.columns):\n",
        "    data = all_factors[col].dropna()\n",
        "    ax.hist(data, bins=40, edgecolor='white', alpha=0.8)\n",
        "    ax.set_title(col)\n",
        "    ax.set_xlabel('Z-score')\n",
        "    ax.axvline(0, color='red', linestyle='--', linewidth=0.8)\n",
        "plt.suptitle('Cross-sectional factor score distributions', y=1.02)\n",
        "plt.tight_layout()\n",
        "plt.show()\n"
      ]
    }
  ],
